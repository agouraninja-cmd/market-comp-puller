# Copy this file to ".env" and fill in your key.
# The .env file is loaded automatically by server.js on startup.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — require a shared password before anyone can run searches.
# Leave it commented out to keep the app open.
# APP_PASSWORD=choose-a-shared-password

# Optional — port the server listens on (defaults to 3000)
# PORT=3000
